  "launchDescriptor": {
    "dockerImage": "${artifactId}:${version}",
    "dockerPull": false,
    "dockerArgs": {
      "HostConfig": {
        "Memory": 715827883,
        "PortBindings": {
          "8081/tcp": [
            {
              "HostPort": "%p"
            }
          ]
        }
      }
    },
    "env": [
      {
        "name": "JAVA_OPTIONS",
        "value": "-XX:MaxRAMPercentage=66.0"
      },
      {
        "name": "ENV",
        "value": "folio"
      },
      {
        "name": "DB_HOST",
        "value": "postgres"
      },
      {
        "name": "DB_PORT",
        "value": "5432"
      },
      {
        "name": "DB_USERNAME",
        "value": "folio_admin"
      },
      {
        "name": "DB_PASSWORD",
        "value": "folio_admin"
      },
      {
        "name": "DB_DATABASE",
        "value": "folio"
      },
      {
        "name": "DB_QUERYTIMEOUT",
        "value": "60000"
      },
      {
        "name": "DB_CHARSET",
        "value": "UTF-8"
      },
      {
        "name": "DB_MAXPOOLSIZE",
        "value": "5"
      },
      {
        "name": "DB_MAXSHAREDPOOLSIZE",
        "value": "3"
      },
      {
        "name": "DB_CONNECTIONRELEASEDELAY",
        "value": "60000"
      },
      {
        "name": "KAFKA_HOST",
        "value": "kafka"
      },
      {
        "name": "KAFKA_PORT",
        "value": "9092"
      },
      {
        "name": "REPLICATION_FACTOR",
        "value": "1"
      },
      {
        "name": "KAFKA_LOCATION_TOPIC_NUM_PARTITIONS",
        "value": "1"
      },
      {
        "name": "KAFKA_LIBRARY_TOPIC_NUM_PARTITIONS",
        "value": "1"
      },
      {
        "name": "KAFKA_CAMPUS_TOPIC_NUM_PARTITIONS",
        "value": "1"
      },
      {
        "name": "KAFKA_INSTITUTION_TOPIC_NUM_PARTITIONS",
        "value": "1"
      },
      {
        "name": "ECS_SERVICE_POINT_SYNC_FEATURE_ENABLED",
        "value": "false"
      }
    ]
  }
