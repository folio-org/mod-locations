<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="MODLOCS-1@@schema-create-table-service_point_user" author="copilot">
    <createTable tableName="service_point_user">
      <column name="id" type="uuid">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="user_id" type="uuid">
        <constraints nullable="false"/>
      </column>
      <column name="service_points_ids" type="uuid[]"/>
      <column name="default_service_point_id" type="uuid">
        <constraints referencedTableName="service_point" referencedColumnNames="id" foreignKeyName="service_point_user_defaultsp_fkey"/>
      </column>
      <column name="created_date" type="timestamp"/>
      <column name="created_by_user_id" type="uuid"/>
      <column name="updated_date" type="timestamp"/>
      <column name="updated_by_user_id" type="uuid"/>
    </createTable>
    <createIndex indexName="service_point_user_userid_idx_unique" tableName="service_point_user" unique="true">
      <column name="user_id"/>
    </createIndex>
    <createIndex indexName="service_point_user_defaultservicepointid_idx" tableName="service_point_user">
      <column name="default_service_point_id"/>
    </createIndex>
  </changeSet>

</databaseChangeLog>
